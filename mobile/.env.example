# Supabase Configuration
# Get these values from your Supabase project dashboard at https://app.supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Server Configuration
PORT=5000

# Expo/Client Configuration
# For local development, this should be your machine's IP address or localhost
EXPO_PUBLIC_DOMAIN=localhost:5000

# Replit Configuration (if deploying on Replit)
# REPLIT_DEV_DOMAIN=your-repl-name.your-username.repl.co
# REPLIT_DOMAINS=your-repl-name.your-username.repl.co

# Node Environment
NODE_ENV=development
